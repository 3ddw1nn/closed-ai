---
import BottomSection from "@/components/BottomSection.astro";
import Hero from "@/components/Hero.astro";
import Sidebar from "@/components/Sidebar.astro";
import Timeline from "@/components/Timeline.astro";
import WackyLogo from "@/components/WackyLogo.astro";
import Layout from "@/layouts/Layout.astro";
---

<Layout>
  <div class="app">
    <Sidebar />
    <div class="chat-main">
      <header class="chat-header">
        <button
          class="mobile-menu-button"
          type="button"
          data-mobile-sidebar-open
          aria-label="Open menu"
          title="Open menu"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M4 7h16" />
            <path d="M4 12h16" />
            <path d="M4 17h16" />
          </svg>
        </button>
        <a href="/" class="header-brand">
          <WackyLogo size={22} />
          ClosedAI
        </a>
        <div class="header-actions">
          <span class="header-note">Not affiliated with OpenAI</span>
          <a
            class="share-button"
            href="#thread-end"
            title="Sharing is how the NYT found out"
          >
            Share
          </a>
        </div>
      </header>
      <div class="thread">
        <Hero />
        <Timeline />
        <BottomSection />
      </div>
    </div>
  </div>
</Layout>
