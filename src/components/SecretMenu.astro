---
// Hidden admin panel: Ctrl+Shift+C, enter the code, get the scraper +
// delete controls. Everything privileged is re-checked server-side in
// api/*.ts — the admin-mode class here is UI only, not a security boundary.
---

<div class="secret-backdrop" data-secret-backdrop hidden></div>
<div
  class="secret-modal"
  data-secret-modal
  role="dialog"
  aria-modal="true"
  aria-label="Admin"
  hidden
>
  <button
    type="button"
    class="secret-close"
    data-secret-close
    aria-label="Close">×</button
  >

  <div data-secret-code-view>
    <h2>closed door</h2>
    <form data-secret-code-form>
      <input
        type="password"
        data-secret-code-input
        autocomplete="off"
        placeholder="code"
      />
      <button type="submit">Unlock</button>
    </form>
    <p class="secret-error" data-secret-error hidden>Wrong code.</p>
  </div>

  <div data-secret-admin-view hidden>
    <h2>Admin</h2>
    <button type="button" class="secret-scrape-btn" data-secret-scrape-btn>
      Run scraper now
    </button>
    <p class="secret-status" data-secret-scrape-status></p>

    <label class="secret-provider-row">
      <span>AI provider (used by "Draft with AI")</span>
      <select data-secret-provider-select>
        <option value="gemini">Gemini Flash</option>
        <option value="mistral">Mistral Small</option>
        <option value="groq">Groq Llama 3.3 70B</option>
        <option value="cerebras">Cerebras GPT-OSS 120B</option>
        <option value="openrouter">OpenRouter (free)</option>
      </select>
    </label>

    <h3>Pending candidates</h3>
    <ul class="secret-pending-list" data-secret-pending-list></ul>
  </div>
</div>

<div class="confirm-backdrop" data-confirm-backdrop hidden></div>
<div
  class="confirm-dialog"
  data-confirm-dialog
  role="alertdialog"
  aria-modal="true"
  hidden
>
  <p data-confirm-message></p>
  <div class="confirm-actions">
    <button type="button" data-confirm-cancel>Cancel</button>
    <button type="button" class="confirm-danger" data-confirm-ok
      >Delete</button
    >
  </div>
</div>

<div class="secret-toast" data-secret-toast hidden></div>

<script>
  const storageKey = "closedai-admin-code";
  const providerStorageKey = "closedai-admin-provider";

  const backdrop = document.querySelector("[data-secret-backdrop]");
  const modal = document.querySelector("[data-secret-modal]");
  const codeView = document.querySelector("[data-secret-code-view]");
  const codeForm = document.querySelector("[data-secret-code-form]");
  const codeInput = document.querySelector(
    "[data-secret-code-input]",
  ) as HTMLInputElement | null;
  const codeError = document.querySelector("[data-secret-error]");
  const adminView = document.querySelector("[data-secret-admin-view]");
  const closeBtn = document.querySelector("[data-secret-close]");
  const scrapeBtn = document.querySelector("[data-secret-scrape-btn]");
  const scrapeStatus = document.querySelector("[data-secret-scrape-status]");
  const pendingList = document.querySelector("[data-secret-pending-list]");
  const toast = document.querySelector("[data-secret-toast]");
  const providerSelect = document.querySelector(
    "[data-secret-provider-select]",
  ) as HTMLSelectElement | null;

  const confirmBackdrop = document.querySelector("[data-confirm-backdrop]");
  const confirmDialog = document.querySelector("[data-confirm-dialog]");
  const confirmMessage = document.querySelector("[data-confirm-message]");
  const confirmCancel = document.querySelector("[data-confirm-cancel]");
  const confirmOk = document.querySelector("[data-confirm-ok]");

  const getStoredCode = () => {
    try {
      return sessionStorage.getItem(storageKey);
    } catch {
      return null;
    }
  };

  const getStoredProvider = () => {
    try {
      return sessionStorage.getItem(providerStorageKey) ?? "gemini";
    } catch {
      return "gemini";
    }
  };

  if (providerSelect) {
    providerSelect.value = getStoredProvider();
    providerSelect.addEventListener("change", () => {
      try {
        sessionStorage.setItem(providerStorageKey, providerSelect.value);
      } catch {
        /* private browsing, selection just won't persist across reloads */
      }
    });
  }

  const showToast = (message: string) => {
    if (!(toast instanceof HTMLElement)) return;
    toast.textContent = message;
    toast.hidden = false;
    setTimeout(() => {
      toast.hidden = true;
    }, 3500);
  };

  const openModal = () => {
    backdrop?.removeAttribute("hidden");
    modal?.removeAttribute("hidden");
    const code = getStoredCode();
    if (code) {
      codeView?.setAttribute("hidden", "");
      adminView?.removeAttribute("hidden");
      modal?.classList.add("is-admin");
      loadPending();
    } else {
      codeView?.removeAttribute("hidden");
      adminView?.setAttribute("hidden", "");
      modal?.classList.remove("is-admin");
      codeInput?.focus();
    }
  };

  const closeModal = () => {
    backdrop?.setAttribute("hidden", "");
    modal?.setAttribute("hidden", "");
  };

  document.addEventListener("keydown", (event) => {
    if (event.ctrlKey && event.shiftKey && event.code === "KeyC") {
      event.preventDefault();
      openModal();
    }
    if (event.key === "Escape") {
      closeModal();
      closeConfirm();
    }
  });

  backdrop?.addEventListener("click", closeModal);
  closeBtn?.addEventListener("click", closeModal);

  codeForm?.addEventListener("submit", async (event) => {
    event.preventDefault();
    const code = codeInput?.value ?? "";
    const res = await fetch("/api/verify-code", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ code }),
    });
    if (res.ok) {
      try {
        sessionStorage.setItem(storageKey, code);
      } catch {
        /* private browsing, session just won't persist across reloads */
      }
      document.documentElement.classList.add("admin-mode");
      codeError?.setAttribute("hidden", "");
      codeView?.setAttribute("hidden", "");
      adminView?.removeAttribute("hidden");
      modal?.classList.add("is-admin");
      loadPending();
    } else {
      codeError?.removeAttribute("hidden");
    }
  });

  // Reveal delete controls immediately if this tab already unlocked earlier
  // this session (the early check in Layout.astro's <head> also does this
  // before paint; this is the post-hydration fallback).
  if (getStoredCode()) {
    document.documentElement.classList.add("admin-mode");
  }

  scrapeBtn?.addEventListener("click", async () => {
    if (!(scrapeBtn instanceof HTMLButtonElement)) return;
    scrapeBtn.disabled = true;
    if (scrapeStatus instanceof HTMLElement) {
      scrapeStatus.textContent = "Triggering…";
    }
    try {
      const res = await fetch("/api/scrape-trigger", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ code: getStoredCode() }),
      });
      if (scrapeStatus instanceof HTMLElement) {
        scrapeStatus.textContent = res.ok
          ? "Scrape started — check back in a minute or two."
          : "Failed to start scrape.";
      }
    } finally {
      scrapeBtn.disabled = false;
    }
  });

  type PendingCandidate = {
    title: string;
    url: string;
    source: string;
    snippet: string;
  };

  type Draft = {
    date: string;
    period: string;
    slug: string;
    prompt: string;
    title: string;
    summary: string;
    body: string[];
    aftermath?: string;
    category: string;
  };

  function buildEditForm(candidate: PendingCandidate, draft: Draft, li: HTMLElement) {
    const form = document.createElement("div");
    form.className = "secret-draft-form";

    const field = (label: string, input: HTMLElement, full = false) => {
      const wrap = document.createElement("label");
      if (full) wrap.className = "field-full";
      const labelText = document.createElement("span");
      labelText.textContent = label;
      wrap.append(labelText, input);
      return wrap;
    };

    const titleInput = document.createElement("input");
    titleInput.value = draft.title;
    const slugInput = document.createElement("input");
    slugInput.value = draft.slug;
    const dateInput = document.createElement("input");
    dateInput.value = draft.date;
    const periodInput = document.createElement("input");
    periodInput.value = draft.period;
    const promptInput = document.createElement("input");
    promptInput.value = draft.prompt;
    const summaryInput = document.createElement("textarea");
    summaryInput.value = draft.summary;
    const bodyInput = document.createElement("textarea");
    bodyInput.className = "secret-draft-body";
    bodyInput.value = draft.body.join("\n\n");
    const aftermathInput = document.createElement("input");
    aftermathInput.value = draft.aftermath ?? "";
    const categorySelect = document.createElement("select");
    for (const cat of ["Legal", "Quality", "Reliability", "Safety", "Policy"]) {
      const opt = document.createElement("option");
      opt.value = cat;
      opt.textContent = cat;
      if (cat === draft.category) opt.selected = true;
      categorySelect.append(opt);
    }

    form.append(
      field("Title", titleInput, true),
      field("Slug", slugInput),
      field("Category", categorySelect),
      field("Date", dateInput),
      field("Period", periodInput),
      field("Prompt bubble", promptInput, true),
      field("Summary", summaryInput, true),
      field("Body (blank line between paragraphs)", bodyInput, true),
      field("Aftermath (optional)", aftermathInput, true),
    );

    const actions = document.createElement("div");
    actions.className = "secret-draft-actions";
    const publishBtn = document.createElement("button");
    publishBtn.type = "button";
    publishBtn.className = "secret-publish-btn";
    publishBtn.textContent = "Publish";
    const cancelBtn = document.createElement("button");
    cancelBtn.type = "button";
    cancelBtn.textContent = "Cancel";
    cancelBtn.addEventListener("click", () => form.remove());
    actions.append(cancelBtn, publishBtn);
    form.append(actions);

    publishBtn.addEventListener("click", async () => {
      publishBtn.disabled = true;
      publishBtn.textContent = "Publishing…";
      const article: Draft = {
        title: titleInput.value,
        slug: slugInput.value,
        date: dateInput.value,
        period: periodInput.value,
        prompt: promptInput.value,
        summary: summaryInput.value,
        body: bodyInput.value.split(/\n\s*\n/).map((p) => p.trim()).filter(Boolean),
        aftermath: aftermathInput.value || undefined,
        category: categorySelect.value,
      };
      try {
        const res = await fetch("/api/publish-article", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            code: getStoredCode(),
            article,
            sourceTitle: candidate.source,
            sourceUrl: candidate.url,
          }),
        });
        if (res.ok) {
          showToast(`Published "${article.title}" — live in ~1-2 min.`);
          li.remove();
        } else {
          showToast("Publish failed — check the console.");
          publishBtn.disabled = false;
          publishBtn.textContent = "Publish";
        }
      } catch {
        showToast("Publish failed — network error.");
        publishBtn.disabled = false;
        publishBtn.textContent = "Publish";
      }
    });

    return form;
  }

  async function loadPending() {
    if (!(pendingList instanceof HTMLElement)) return;
    pendingList.textContent = "Loading…";
    try {
      const res = await fetch("/pending.json", { cache: "no-store" });
      const items: PendingCandidate[] = res.ok ? await res.json() : [];

      if (items.length === 0) {
        pendingList.textContent = "Nothing pending.";
        return;
      }

      pendingList.replaceChildren(
        ...items.map((item) => {
          const li = document.createElement("li");
          li.className = "secret-pending-item";

          const link = document.createElement("a");
          link.href = item.url;
          link.target = "_blank";
          link.rel = "noopener noreferrer";
          link.textContent = item.title || item.url;
          li.append(link);

          const meta = document.createElement("p");
          meta.className = "secret-pending-meta";
          meta.textContent = item.source;
          li.append(meta);

          const draftBtn = document.createElement("button");
          draftBtn.type = "button";
          draftBtn.textContent = "Draft with AI";
          draftBtn.addEventListener("click", async () => {
            draftBtn.disabled = true;
            draftBtn.textContent = "Drafting…";
            try {
              const res = await fetch("/api/draft-article", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({
                  code: getStoredCode(),
                  candidate: item,
                  provider: getStoredProvider(),
                }),
              });
              const json = await res.json();
              if (res.ok && json.article) {
                li.querySelector(".secret-draft-form")?.remove();
                li.append(buildEditForm(item, json.article, li));
                draftBtn.textContent = "Re-draft with AI";
              } else {
                showToast(json.error ?? "Draft failed.");
              }
            } catch {
              showToast("Draft failed — network error.");
            } finally {
              draftBtn.disabled = false;
            }
          });
          li.append(draftBtn);

          return li;
        }),
      );
    } catch {
      pendingList.textContent = "Couldn't load pending.json.";
    }
  }

  // --- Delete flow, wired via event delegation since the trash buttons
  // live in Timeline.astro cards and the [slug].astro article page. ---
  let pendingDeleteSlug: string | null = null;
  let pendingDeleteButton: HTMLElement | null = null;

  const closeConfirm = () => {
    confirmBackdrop?.setAttribute("hidden", "");
    confirmDialog?.setAttribute("hidden", "");
    pendingDeleteSlug = null;
    pendingDeleteButton = null;
  };

  document.addEventListener("click", (event) => {
    const trigger = (event.target as HTMLElement)?.closest(
      "[data-delete-slug]",
    );
    if (!trigger) return;
    pendingDeleteSlug = trigger.getAttribute("data-delete-slug");
    pendingDeleteButton = trigger as HTMLElement;
    if (confirmMessage instanceof HTMLElement) {
      const title = trigger.getAttribute("data-delete-title") ?? "this";
      confirmMessage.textContent = `Delete "${title}"? This removes it from the live site.`;
    }
    confirmBackdrop?.removeAttribute("hidden");
    confirmDialog?.removeAttribute("hidden");
  });

  confirmBackdrop?.addEventListener("click", closeConfirm);
  confirmCancel?.addEventListener("click", closeConfirm);

  confirmOk?.addEventListener("click", async () => {
    if (!pendingDeleteSlug) return;
    const slug = pendingDeleteSlug;
    const button = pendingDeleteButton;
    closeConfirm();

    document.getElementById(`event-${slug}`)?.remove();
    if (button?.closest("article.event-page")) {
      showToast("Deleting — you'll be redirected.");
      setTimeout(() => {
        window.location.href = "/";
      }, 1200);
    }

    try {
      const res = await fetch("/api/delete-article", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ code: getStoredCode(), slug }),
      });
      showToast(
        res.ok
          ? "Deleted — live in ~1-2 min."
          : "Delete failed — check the console.",
      );
    } catch {
      showToast("Delete failed — network error.");
    }
  });
</script>

<style is:global>
  .secret-backdrop,
  .confirm-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
    z-index: 90;
  }

  .secret-modal {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 91;
    width: min(26rem, calc(100vw - 2rem));
    max-height: calc(100vh - 4rem);
    overflow-y: auto;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 0.9rem;
    padding: 1.5rem;
    transition: width 0.15s ease;
  }

  .secret-modal.is-admin {
    width: min(56rem, calc(100vw - 3rem));
    padding: 1.75rem 2rem;
  }

  .secret-modal h2 {
    margin: 0 0 1rem;
    font-size: 1.05rem;
  }

  .secret-modal h3 {
    margin: 1.25rem 0 0.5rem;
    font-size: 0.85rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .secret-close {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    background: none;
    border: none;
    color: var(--muted);
    font-size: 1.3rem;
    line-height: 1;
    cursor: pointer;
  }

  [data-secret-code-form] {
    display: flex;
    gap: 0.5rem;
  }

  [data-secret-code-input] {
    flex: 1;
    background: var(--bubble);
    border: 1px solid var(--line);
    border-radius: 0.5rem;
    padding: 0.5rem 0.7rem;
    color: var(--ink);
  }

  [data-secret-code-form] button,
  .secret-scrape-btn {
    background: var(--accent);
    color: #04120d;
    border: none;
    border-radius: 0.5rem;
    padding: 0.5rem 0.9rem;
    font-weight: 600;
    cursor: pointer;
  }

  .secret-scrape-btn {
    width: 100%;
  }

  .secret-error {
    color: var(--error-ink);
    font-size: 0.85rem;
    margin: 0.6rem 0 0;
  }

  .secret-status {
    color: var(--muted);
    font-size: 0.85rem;
    min-height: 1.2em;
  }

  .secret-provider-row {
    display: grid;
    gap: 0.35rem;
    margin-top: 1rem;
  }

  .secret-provider-row span {
    font-size: 0.72rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .secret-provider-row select {
    background: var(--bubble);
    border: 1px solid var(--line);
    border-radius: 0.5rem;
    padding: 0.5rem 0.7rem;
    color: var(--ink);
    font-size: 0.9rem;
    font-family: inherit;
  }

  .secret-pending-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.6rem;
  }

  .secret-pending-item {
    background: var(--surface-raised);
    border: 1px solid var(--line);
    border-radius: 0.6rem;
    padding: 0.6rem 0.75rem;
    display: grid;
    gap: 0.3rem;
  }

  .secret-pending-item a {
    color: var(--ink);
    font-size: 0.9rem;
  }

  .secret-pending-meta {
    margin: 0;
    color: var(--muted);
    font-size: 0.75rem;
  }

  .secret-pending-item button {
    justify-self: start;
    background: none;
    border: 1px solid var(--line);
    border-radius: 0.4rem;
    color: var(--ink-soft);
    padding: 0.25rem 0.55rem;
    font-size: 0.75rem;
    cursor: pointer;
  }

  .secret-draft-form {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem 1.5rem;
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--line);
  }

  .secret-draft-form label {
    display: grid;
    gap: 0.35rem;
  }

  .secret-draft-form label > span {
    font-size: 0.72rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .secret-draft-form .field-full {
    grid-column: 1 / -1;
  }

  .secret-draft-form input,
  .secret-draft-form textarea,
  .secret-draft-form select {
    width: 100%;
    box-sizing: border-box;
    background: var(--bubble);
    border: 1px solid var(--line);
    border-radius: 0.5rem;
    padding: 0.55rem 0.75rem;
    color: var(--ink);
    font-size: 0.9rem;
    line-height: 1.4;
    font-family: inherit;
  }

  .secret-draft-form input:focus,
  .secret-draft-form textarea:focus,
  .secret-draft-form select:focus {
    outline: none;
    border-color: var(--ink-soft);
  }

  .secret-draft-body {
    min-height: 14rem;
    resize: vertical;
    line-height: 1.6;
  }

  .secret-draft-actions {
    grid-column: 1 / -1;
    display: flex;
    justify-content: flex-end;
    gap: 0.6rem;
    margin-top: 0.4rem;
  }

  .secret-draft-actions button {
    padding: 0.5rem 1.1rem;
    border-radius: 0.5rem;
    font-size: 0.9rem;
    cursor: pointer;
  }

  .secret-draft-actions button:not(.secret-publish-btn) {
    background: var(--bubble);
    border: 1px solid var(--line);
    color: var(--ink);
  }

  .secret-publish-btn {
    background: var(--accent);
    border: none;
    color: #04120d;
    font-weight: 600;
  }

  .confirm-dialog {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 91;
    width: min(22rem, calc(100vw - 2rem));
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 0.9rem;
    padding: 1.25rem;
  }

  .confirm-actions {
    display: flex;
    justify-content: flex-end;
    gap: 0.6rem;
    margin-top: 1rem;
  }

  .confirm-actions button {
    border-radius: 0.5rem;
    padding: 0.4rem 0.8rem;
    cursor: pointer;
    border: 1px solid var(--line);
    background: var(--bubble);
    color: var(--ink);
  }

  .confirm-danger {
    background: var(--error-bg);
    border-color: var(--error-border);
    color: var(--error-ink);
  }

  .secret-toast {
    position: fixed;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 92;
    background: var(--surface-raised);
    border: 1px solid var(--line);
    border-radius: 0.6rem;
    padding: 0.6rem 1rem;
    font-size: 0.85rem;
    color: var(--ink);
  }
</style>
