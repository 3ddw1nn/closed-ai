---
import { timelineEvents } from "@/data/timeline";
import WackyLogo from "./WackyLogo.astro";

const eventsByYear = new Map<string, typeof timelineEvents>();
for (const event of [...timelineEvents].sort((a, b) =>
  a.date < b.date ? 1 : -1,
)) {
  const year = event.date.slice(0, 4);
  eventsByYear.set(year, [...(eventsByYear.get(year) ?? []), event]);
}
---

<aside class="sidebar" aria-label="Chat history (satirical)">
  <div class="sidebar-rail" aria-label="Collapsed navigation">
    <button
      class="rail-logo"
      type="button"
      data-sidebar-toggle
      title="Open sidebar"
      aria-label="Open sidebar"
    >
      <WackyLogo size={31} />
    </button>
    <nav class="rail-nav" aria-label="Quick actions">
      <button
        class="rail-button"
        type="button"
        data-sidebar-open
        title="Open sidebar"
        aria-label="Open sidebar"
      >
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 20h9" />
          <path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L8 18l-4 1 1-4Z" />
        </svg>
      </button>
      <button
        class="rail-button"
        type="button"
        data-sidebar-open
        title="Open sidebar"
        aria-label="Open sidebar"
      >
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <circle cx="10.5" cy="10.5" r="7.2" />
          <path d="m16 16 5 5" />
        </svg>
      </button>
      <button
        class="rail-button"
        type="button"
        data-sidebar-open
        title="Open sidebar"
        aria-label="Open sidebar"
      >
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M15.5 3.5 20.5 8.5" />
          <path d="m14.2 4.8-5.7 5.7-4.3 1.4 7.9 7.9 1.4-4.3 5.7-5.7" />
          <path d="M8.8 15.2 3.5 20.5" />
        </svg>
      </button>
      <button
        class="rail-button"
        type="button"
        data-sidebar-open
        title="Open sidebar"
        aria-label="Open sidebar"
      >
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M20 11.5a7.5 7.5 0 0 1-8 7.5 8.7 8.7 0 0 1-3.5-.8L4 19.5l1.3-4.1A7.2 7.2 0 0 1 4 11.5 7.5 7.5 0 0 1 12 4a7.5 7.5 0 0 1 8 7.5Z" />
        </svg>
      </button>
    </nav>
    <button
      class="rail-account"
      type="button"
      data-sidebar-toggle
      title="Open sidebar"
      aria-label="Open sidebar"
    >
      <span class="account-avatar" aria-hidden="true">You</span>
    </button>
  </div>

  <div class="sidebar-expanded">
    <div class="sidebar-top">
      <a href="/" class="sidebar-brand">
        <WackyLogo size={26} />
        <span>ClosedAI</span>
      </a>
      <button
        class="sidebar-toggle"
        type="button"
        data-sidebar-toggle
        aria-label="Collapse sidebar"
        title="Collapse sidebar"
      >
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <rect x="4" y="5" width="16" height="14" rx="3" />
          <path d="M12 5v14" />
        </svg>
      </button>
    </div>

    <button class="new-chat-button" type="button" disabled>
      <span>＋ New incident</span>
      <span>any minute now</span>
    </button>

    <div class="sidebar-scroll">
      {
        [...eventsByYear.entries()].map(([year, events]) => (
          <nav class="sidebar-section">
            <div class="sidebar-label">{year}</div>
            {events.map((event) => (
              <a
                class="sidebar-item"
                href={`/#event-${event.slug}`}
                title={event.title}
              >
                {event.title}
              </a>
            ))}
          </nav>
        ))
      }
    </div>

    <div class="sidebar-footer">
      <a class="upgrade-card" href="/#thread-end">
        <strong>Upgrade to Grief Pro</strong>
        More wrongdoing per month. $200/mo, obviously.
      </a>
      <div class="sidebar-account">
        <span class="account-avatar" aria-hidden="true">You</span>
        <span>
          <span class="account-name">You</span><br />
          <span class="account-plan">Free plan (they raised $40B)</span>
        </span>
      </div>
    </div>
  </div>
</aside>

<div class="sidebar-backdrop" data-sidebar-backdrop aria-hidden="true">
</div>

<script>
  const appShell = document.querySelector(".app");
  const sidebar = document.querySelector(".sidebar");
  const sidebarToggles = document.querySelectorAll("[data-sidebar-toggle]");
  const sidebarOpeners = document.querySelectorAll("[data-sidebar-open]");
  const storageKey = "closedai-sidebar-collapsed";

  const mobileSidebarOpeners = document.querySelectorAll(
    "[data-mobile-sidebar-open]",
  );
  const sidebarBackdrop = document.querySelector("[data-sidebar-backdrop]");

  const setMobileSidebarOpen = (open: boolean) => {
    appShell?.classList.toggle("mobile-sidebar-open", open);
    sidebar?.setAttribute("aria-expanded", String(open));
  };

  for (const opener of mobileSidebarOpeners) {
    opener.addEventListener("click", () => setMobileSidebarOpen(true));
  }

  sidebarBackdrop?.addEventListener("click", () =>
    setMobileSidebarOpen(false),
  );

  sidebar?.addEventListener("click", (event) => {
    if ((event.target as HTMLElement).closest("a")) {
      setMobileSidebarOpen(false);
    }
  });

  const setSidebarCollapsed = (collapsed: boolean) => {
    appShell?.classList.toggle("sidebar-collapsed", collapsed);
    sidebar?.setAttribute("aria-expanded", String(!collapsed));

    for (const toggle of sidebarToggles) {
      toggle.setAttribute(
        "aria-label",
        collapsed ? "Open sidebar" : "Collapse sidebar",
      );
      toggle.setAttribute(
        "title",
        collapsed ? "Open sidebar" : "Collapse sidebar",
      );
    }

    try {
      localStorage.setItem(storageKey, String(collapsed));
    } catch {
      /* Ignore private browsing storage failures. */
    }
  };

  let savedCollapsed = false;
  try {
    savedCollapsed = localStorage.getItem(storageKey) === "true";
  } catch {
    savedCollapsed = false;
  }

  setSidebarCollapsed(savedCollapsed);

  const mobileMediaQuery = window.matchMedia("(max-width: 1023.98px)");

  for (const toggle of sidebarToggles) {
    toggle.addEventListener("click", () => {
      if (mobileMediaQuery.matches) {
        setMobileSidebarOpen(false);
      } else {
        setSidebarCollapsed(!appShell?.classList.contains("sidebar-collapsed"));
      }
    });
  }

  for (const opener of sidebarOpeners) {
    opener.addEventListener("click", () => {
      setSidebarCollapsed(false);
    });
  }
</script>
