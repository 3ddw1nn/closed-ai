---
import WackyLogo from "./WackyLogo.astro";
---

<section class="ending" id="thread-end">
  <div class="typing-row">
    <span class="assistant-avatar" aria-hidden="true">
      <WackyLogo size={22} />
    </span>
    <p class="typing-line">
      Remember kids… not all whistleblowers are <strong>suicidal</strong><span
        class="typing-dots"
        aria-hidden="true"><span></span><span></span><span></span></span
      >
    </p>
  </div>

  <div class="error-card" role="alert">
    <span class="error-icon" aria-hidden="true">!</span>
    <div class="error-text">
      <strong>Something went wrong.</strong>
      <span>
        Repeatedly. Since 2023. If this issue persists, please check the
        thread above.
      </span>
    </div>
    <button id="regenerate" class="regenerate-button" type="button">
      ⟳ Regenerate company
    </button>
  </div>

  <div class="composer">
    <div
      class="composer-bar"
      title="You've reached your message limit. Upgrade to Grief Pro."
    >
      <span class="composer-plus" aria-hidden="true">＋</span>
      <span class="composer-placeholder">Message ClosedAI…</span>
      <span class="composer-send" aria-hidden="true">↑</span>
    </div>
    <p class="composer-note">
      ClosedAI can make mistakes. Check important info. (See above.)
    </p>
  </div>

  <nav class="social-links" aria-label="Creator links">
    <a
      class="social-link"
      href="https://x.com/edWasNotHere"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Edward on X"
      title="Edward on X"
    >
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path d="M4 4h4.7l3.8 5.4L17.2 4H20l-6.2 7.1L20.5 20h-4.7l-4.2-5.9L6.5 20H3.7l6.6-7.6L4 4Z" />
      </svg>
      <span>X</span>
    </a>
    <a
      class="social-link"
      href="https://github.com/3ddw1nn"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Edward on GitHub"
      title="Edward on GitHub"
    >
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path d="M12 2.8a9.2 9.2 0 0 0-2.9 17.9c.5.1.7-.2.7-.5v-1.8c-2.8.6-3.4-1.2-3.4-1.2-.5-1.1-1.1-1.4-1.1-1.4-.9-.6.1-.6.1-.6 1 0 1.6 1.1 1.6 1.1.9 1.6 2.4 1.1 2.9.9.1-.7.4-1.1.7-1.4-2.3-.3-4.6-1.1-4.6-4.8 0-1.1.4-1.9 1-2.6-.1-.3-.4-1.3.1-2.6 0 0 .8-.3 2.7 1a9.3 9.3 0 0 1 4.9 0c1.9-1.3 2.7-1 2.7-1 .5 1.3.2 2.3.1 2.6.7.7 1 1.6 1 2.6 0 3.7-2.3 4.5-4.6 4.8.4.3.7.9.7 1.8v2.6c0 .3.2.6.7.5A9.2 9.2 0 0 0 12 2.8Z" />
      </svg>
      <span>GitHub</span>
    </a>
  </nav>
</section>

<script>
  const regenerate = document.querySelector("#regenerate");

  regenerate?.addEventListener("click", () => {
    const label = regenerate as HTMLButtonElement;
    label.textContent = "⟳ Regenerating…";
    setTimeout(() => {
      label.textContent = "⟳ Same company generated";
      setTimeout(() => {
        window.scrollTo({ top: 0, behavior: "smooth" });
        label.textContent = "⟳ Regenerate company";
      }, 900);
    }, 900);
  });
</script>
