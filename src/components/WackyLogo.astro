---
/**
 * A rude little parody mark: dog rear, tiny OpenAI-ish knot in the center.
 */
interface Props {
  size?: number;
  class?: string;
}

const { size = 48, class: className = "" } = Astro.props;
---

<svg
  class={`wacky-logo ${className}`}
  width={size}
  height={size}
  viewBox="0 0 120 120"
  fill="none"
  aria-hidden="true"
>
  <g
    class="wacky-logo-body"
    stroke="currentColor"
    stroke-width="4.2"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <path d="M26 66 C26 44 41 30 60 30 C79 30 94 44 94 66"></path>
    <path d="M31 67 C21 81 30 100 46 101 C55 102 59 96 60 88"></path>
    <path d="M89 67 C99 81 90 100 74 101 C65 102 61 96 60 88"></path>
    <path d="M43 95 C38 108 26 109 22 99"></path>
    <path d="M77 95 C82 108 94 109 98 99"></path>
    <path d="M60 30 C58 20 66 14 76 18 C85 21 86 31 78 35"></path>
    <path d="M18 68 C15 62 15 56 20 51"></path>
    <path d="M102 68 C105 62 105 56 100 51"></path>
  </g>
  <g
    class="wacky-logo-knot"
    stroke="currentColor"
    stroke-width="1.9"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <path d="M60 48 C66 48 70 52 71 58 C72 63 69 68 64 70 L58 74"></path>
    <path d="M60 48 C66 48 70 52 71 58 C72 63 69 68 64 70 L58 74" transform="rotate(60 60 62)"></path>
    <path d="M60 48 C66 48 70 52 71 58 C72 63 69 68 64 70 L58 74" transform="rotate(120 60 62)"></path>
    <path
      d="M60 48 C66 48 70 52 71 58 C72 63 69 68 64 70 L58 74"
      transform="rotate(180 60 62)"></path>
    <path
      d="M60 48 C66 48 70 52 71 58 C72 63 69 68 64 70 L58 74"
      transform="rotate(240 60 62)"></path>
    <path
      d="M60 48 C66 48 70 52 71 58 C72 63 69 68 64 70 L58 74"
      transform="rotate(300 60 62)"></path>
    <circle cx="60" cy="62" r="3.2" fill="var(--canvas)" stroke-width="1.6"></circle>
  </g>
</svg>
