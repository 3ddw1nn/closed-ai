---
/**
 * A compact monochrome knot mark inspired by the app chrome around it.
 */
interface Props {
  size?: number;
  class?: string;
}

const { size = 48, class: className = "" } = Astro.props;
---

<svg
  class={`wacky-logo ${className}`}
  width={size}
  height={size}
  viewBox="0 0 120 120"
  fill="none"
  aria-hidden="true"
>
  <g class="wacky-logo-body" fill="currentColor">
    <rect x="50" y="12" width="20" height="48" rx="10"></rect>
    <rect x="50" y="12" width="20" height="48" rx="10" transform="rotate(60 60 60)"></rect>
    <rect x="50" y="12" width="20" height="48" rx="10" transform="rotate(120 60 60)"></rect>
    <rect x="50" y="12" width="20" height="48" rx="10" transform="rotate(180 60 60)"></rect>
    <rect x="50" y="12" width="20" height="48" rx="10" transform="rotate(240 60 60)"></rect>
    <rect x="50" y="12" width="20" height="48" rx="10" transform="rotate(300 60 60)"></rect>
    <circle cx="60" cy="60" r="14" fill="var(--canvas)"></circle>
    <circle
      cx="60"
      cy="60"
      r="8"
      fill="none"
      stroke="currentColor"
      stroke-width="7"></circle>
  </g>
</svg>
