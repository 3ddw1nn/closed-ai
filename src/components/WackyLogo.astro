---
/**
 * A wobbly six-loop knot: recognizably OpenAI-ish, but knocked off-axis.
 */
interface Props {
  size?: number;
  class?: string;
}

const { size = 48, class: className = "" } = Astro.props;
---

<svg
  class={`wacky-logo ${className}`}
  width={size}
  height={size}
  viewBox="0 0 120 120"
  fill="none"
  aria-hidden="true"
>
  <g
    class="wacky-logo-body"
    stroke="currentColor"
    stroke-width="8.5"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <path d="M60 18 C76 17 89 27 93 42 C96 54 90 67 78 75 L62 85"></path>
    <path
      d="M60 18 C76 17 89 27 93 42 C96 54 90 67 78 75 L62 85"
      transform="rotate(58 60 60) translate(1 -1)"></path>
    <path
      d="M60 18 C76 17 89 27 93 42 C96 54 90 67 78 75 L62 85"
      transform="rotate(121 60 60) translate(-1 1)"></path>
    <path
      d="M60 18 C76 17 89 27 93 42 C96 54 90 67 78 75 L62 85"
      transform="rotate(178 60 60) translate(0 2)"></path>
    <path
      d="M60 18 C76 17 89 27 93 42 C96 54 90 67 78 75 L62 85"
      transform="rotate(242 60 60) translate(-2 -1)"></path>
    <path
      d="M60 18 C76 17 89 27 93 42 C96 54 90 67 78 75 L62 85"
      transform="rotate(304 60 60) translate(2 0)"></path>
    <path
      class="wacky-logo-kink"
      d="M60 40 78 50 78 70 60 80 42 70 42 50 Z"
      stroke-width="6"></path>
    <path class="wacky-logo-crack" d="M78 25 83 20 M88 31 95 29" stroke-width="3"></path>
  </g>
</svg>
