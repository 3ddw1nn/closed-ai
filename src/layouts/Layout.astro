---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Everything That Went Wrong With OpenAI — closedai.rip",
  description = "One long, cursed ChatGPT conversation about every OpenAI incident since 2023. Independent parody. Not affiliated with OpenAI.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link
      rel="icon"
      href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 120 120'><rect width='120' height='120' rx='24' fill='black'/><g fill='white'><rect x='50' y='12' width='20' height='48' rx='10'/><rect x='50' y='12' width='20' height='48' rx='10' transform='rotate(60 60 60)'/><rect x='50' y='12' width='20' height='48' rx='10' transform='rotate(120 60 60)'/><rect x='50' y='12' width='20' height='48' rx='10' transform='rotate(180 60 60)'/><rect x='50' y='12' width='20' height='48' rx='10' transform='rotate(240 60 60)'/><rect x='50' y='12' width='20' height='48' rx='10' transform='rotate(300 60 60)'/><circle cx='60' cy='60' r='14' fill='black'/><circle cx='60' cy='60' r='8' fill='none' stroke='white' stroke-width='7'/></g></svg>"
    />
    <script is:inline>
      document.documentElement.dataset.theme = "dark";
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
